# ===========================
# Application
# ===========================
NODE_ENV=local
PORT=3000
APPLICATION_ID=poc-whatsapp
VERSION=1
TZ=America/Lima

# ===========================
# Logging
# LOG_LEVEL: OFF | ERROR | WARN | INFO | DEBUG
# ===========================
LOG_LEVEL=DEBUG
LOG_FORMAT=

# ===========================
# Security
# ===========================
PEPPER_PASSWORD=
API_KEY_PREFIX=biz_

# ===========================
# JWT
# JWT_SECRET: clave secreta para firmar los tokens (NO hardcodear)
# JWT_ACCESS_EXPIRES_IN: TTL del access token (por defecto 15m)
# JWT_REFRESH_EXPIRES_IN: TTL del refresh token (por defecto 7d)
# ===========================
JWT_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================
# Database (PostgreSQL)
# ===========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=poc_whatsapp

# ===========================
# Cron
# ===========================
CRON_DAILY_METRICS=0 2 * * *
